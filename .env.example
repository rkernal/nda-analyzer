# --- Anthropic (server-side only; never NEXT_PUBLIC_) ---
# From this tool's OWN Anthropic Workspace (set a spend limit on that Workspace).
ANTHROPIC_API_KEY=
# Deep-compare pass — the judgment-heavy categorization + risk scoring.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Well-defined sub-prompts (e.g. clause extraction) — cheaper/faster tier.
ANTHROPIC_MODEL_FAST=claude-haiku-4-5

# --- Auth.js (per-user login, same accounts as the Sandbox) ---
# This tool's own session secret — generate fresh: `openssl rand -base64 32`.
# Does NOT need to match the Sandbox (sessions are per-app).
AUTH_SECRET=

# --- Upstash Redis (the SHARED user store + this tool's records) ---
# Use the SAME values as the Sandbox so sign-in reads the same supervisor accounts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
